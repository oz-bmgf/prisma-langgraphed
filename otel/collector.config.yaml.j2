extensions:
  health_check:
    endpoint: 0.0.0.0:13133

receivers:
  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317
        # NQPR investigation loops emit large spans (full prompt/completion text);
        # raise above the 4 MiB default to prevent RESOURCE_EXHAUSTED on oversized messages.
        max_recv_msg_size_mib: 20
      http:
        endpoint: 0.0.0.0:4318

processors:
  memory_limiter:
    check_interval: 1s
    # Soft cap raised to 6 144 MiB (6 GB) to match the 8 GB Docker limit.
    # The collector returns RESOURCE_EXHAUSTED to senders only when it exceeds
    # this value — giving more headroom before rejecting spans during LLM bursts.
    limit_mib: 6144
    spike_limit_mib: 1536 # 1.5 GB surge allowance above limit_mib

  batch:
    send_batch_size: 512
    send_batch_max_size: 1024
    timeout: 5s

exporters:
{% if phoenix_enabled %}
  otlp_http/phoenix:
    traces_endpoint: "{{ phoenix_endpoint }}"
    retry_on_failure:
      enabled: true
      initial_interval: 5s
      max_interval: 60s
      max_elapsed_time: 300s
    sending_queue:
      enabled: true
      num_consumers: 4
      queue_size: 5000
{% endif %}
{% if langfuse_enabled %}
  otlp_http/langfuse:
    traces_endpoint: "{{ langfuse_endpoint }}"
    headers:
      Authorization: "Basic {{ langfuse_auth_header }}"
    retry_on_failure:
      enabled: true
      initial_interval: 5s
      max_interval: 60s
      max_elapsed_time: 300s
    sending_queue:
      enabled: true
      num_consumers: 4
      queue_size: 5000
{% endif %}

service:
  extensions: [health_check]
  pipelines:
    traces:
      receivers:  [otlp]
      processors: [memory_limiter, batch]
      exporters:
{% if phoenix_enabled %}
        - otlp_http/phoenix
{% endif %}
{% if langfuse_enabled %}
        - otlp_http/langfuse
{% endif %}
