# ── API Keys: required ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=          # Anthropic API key — required for all LLM nodes
OPENAI_API_KEY=             # OpenAI API key — required for embeddings and vision

# ── API Keys: optional providers ────────────────────────────────────────────
SERPAPI_API_KEY=            # Google Scholar searches via SerpAPI
SEMANTIC_SCHOLAR_API_KEY=   # Semantic Scholar API key
COHERE_API_KEY=             # Cohere API key

# ── Model defaults ────────────────────────────────────────────────────────────
# Override to pin a specific model for each role.
NQPR_RESEARCH_MODEL=claude-sonnet-4-6       # investigation/research LLM calls
NQPR_SYNTHESIS_MODEL=claude-sonnet-4-6      # synthesis and report-writing LLM calls
NQPR_ANALYSIS_MODEL=claude-sonnet-4-6       # analysis LLM calls
NQPR_FAST_MODEL=claude-haiku-4-5-20251001   # fast/cheap model (query rewriting, verification)
NQPR_STRONG_MODEL=claude-opus-4-7           # highest-capability model (gs_verifier)
NQPR_VISION_MODEL=gpt-4o                    # vision/multimodal model
NQPR_EMBEDDING_MODEL=text-embedding-3-small # OpenAI embedding model

# ── Model parameters ──────────────────────────────────────────────────────────
NQPR_MAX_TOKENS=4096                        # default max_tokens for LLM calls
NQPR_THINKING_BUDGET_TOKENS=8000            # extended thinking budget (Anthropic)
NQPR_VERIFIER_MAX_TOKENS=2048               # max_tokens for dual verifier calls
NQPR_MAX_INVESTIGATION_ITERATIONS=12        # max iterations in investigation loops
NQPR_MAX_LINK_WORKERS=16                    # causal link investigation concurrency

# ── Execution environment ─────────────────────────────────────────────────────
# local: langgraph dev with in-memory checkpointer (default)
# docker: docker compose up — Postgres checkpointer (set automatically by docker-compose.yml)
ENV=local

# ── Checkpointer ──────────────────────────────────────────────────────────────
# Backend: sqlite (local dev) or postgres (docker / production)
NQPR_CHECKPOINTER_BACKEND=sqlite

# SQLite checkpoint path (sqlite backend only)
NQPR_CHECKPOINT_DB=~/.nqpr_checkpoints/checkpoints.db

# PostgreSQL DSN (postgres backend only).
# docker-compose.yml sets this automatically; override here for an external DB.
# DATABASE_URL is the alias read by `langgraph dev` as --postgres-uri.
# NQPR_CHECKPOINT_POSTGRES_DSN=postgresql://langgraph:langgraph@localhost:5432/langgraph
# DATABASE_URL=postgresql://langgraph:langgraph@localhost:5432/langgraph

# PostgreSQL connection pool size
NQPR_CHECKPOINT_PG_MAX_CONNECTIONS=10

# Set to true only for interactive sessions that need human approval at
# interrupt nodes. Default false — pipeline runs unattended end to end.
NQPR_HUMAN_INTERRUPTS=false

# ── Paths ─────────────────────────────────────────────────────────────────────
NQPR_COLLECTIONS_BASE=~/qpr-collections                 # root of all program collections

# ── Search backend ────────────────────────────────────────────────────────────
NQPR_SEARCH_BACKEND=local   # local | qdrant | azure
# local: reads vectors.npy + chunks.sqlite from the program's embedding_index/
# qdrant: set QDRANT_URL and QDRANT_API_KEY below
# azure: set AZURE_SEARCH_ENDPOINT and AZURE_SEARCH_KEY below

NQPR_EMBED_DIM=1536                  # embedding vector dimension
NQPR_TOP_K_DEFAULT=20                # default search result count
NQPR_TOP_K_INVESTMENT_SEARCH=25      # investment-scoped search result count
NQPR_TOP_K_PORTFOLIO_SEARCH=10       # portfolio-wide search result count

QDRANT_URL=                 # e.g. http://localhost:6333
QDRANT_API_KEY=             # leave blank for unauthenticated local Qdrant

AZURE_SEARCH_ENDPOINT=      # e.g. https://<service>.search.windows.net
AZURE_SEARCH_KEY=           # Azure Cognitive Search admin key

# ── Thresholds ────────────────────────────────────────────────────────────────
NQPR_SIMILARITY_THRESHOLD=0.85       # minimum similarity score for retrieval
NQPR_CHUNK_TARGET_SIZE=1000          # target chunk size in characters
NQPR_CHUNK_MAX_SIZE=2000             # maximum chunk size in characters
NQPR_CONTEXT_BUDGET_CHARS=420000     # maximum context window budget in characters
NQPR_RECENCY_BOOST_PER_YEAR=0.00005  # score boost per year of document recency
NQPR_RECENCY_BASELINE_YEAR=2020      # baseline year for recency boost calculation

# ── Deep Web research ─────────────────────────────────────────────────────────
NQPR_DEEP_WEB_MODEL=o3-deep-research         # primary model (OpenAI Responses API)
NQPR_DEEP_WEB_FALLBACK_MODEL=gpt-4o          # fallback when primary is unavailable
NQPR_DEEP_WEB_TIMEOUT=300                    # seconds per research call
NQPR_DEEP_WEB_MAX_ROUNDS=3                   # max fallback iterative search rounds

# ── Literature retrieval ──────────────────────────────────────────────────────
EDISON_PLATFORM_API_KEY=                     # required for Edison research tasks
NQPR_EDISON_TIMEOUT=2400                     # seconds (Edison jobs take ~30 min)
NQPR_EDISON_MAX_CONCURRENT=4                 # max parallel Edison queries
NQPR_SLR_TIMEOUT=600                         # seconds per SLR run
NQPR_LBD_TIMEOUT=600                         # seconds per LBD run

# ── Asta (Semantic Scholar MCP) ───────────────────────────────────────────────
ASTA_API_KEY=                                # Bearer token for Asta MCP endpoint
ASTA_ENDPOINT=https://asta-tools.allen.ai/mcp/v1

# ── OpenAlex ──────────────────────────────────────────────────────────────────
OPENALEX_API_KEY=                            # premium pool API key
OPENALEX_EMAIL=                              # polite pool — identify your app (recommended)
NQPR_OPENALEX_MAX_RESULTS=50                 # default max results per OpenAlex search

# ── Observability ─────────────────────────────────────────────────────────────
# Tracing architecture: app → local otel-collector → Phoenix + Langfuse
# observability/tracing.py sends all spans via a single gRPC BatchSpanProcessor
# to the otel-collector container.  The collector fans out to Phoenix and Langfuse
# based on the PHOENIX_*/LANGFUSE_* vars below.  LangSmith stays on its own
# native LANGCHAIN_TRACING_V2 SDK path.
#
# To toggle backends or change endpoints: edit this file, then rebuild:
#   docker compose build otel-collector && docker compose up -d otel-collector

# Master on/off switch — set false in CI/CD to skip all OTEL initialisation.
TRACING_ENABLED=true

LLM_TRACE_FILE=             # optional — path to a .jsonl file for LLM call traces

# ── OTEL service identity ──────────────────────────────────────────────────────
OTEL_SERVICE_NAME=prisma-langgraphed
# gRPC endpoint for the local collector.
# docker-compose.yml overrides this to http://otel-collector:4317 for the graph
# service; keep http://localhost:4317 for local dev without Docker.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── BatchSpanProcessor tuning (app → collector) ───────────────────────────────
# These match the OpenTelemetry spec names; the SDK also reads them automatically.
OTEL_BSP_MAX_QUEUE_SIZE=2048          # max spans buffered before dropping
OTEL_BSP_SCHEDULE_DELAY_MILLIS=5000   # export interval (ms)
OTEL_BSP_MAX_EXPORT_BATCH_SIZE=512    # spans per export request
OTEL_BSP_EXPORT_TIMEOUT_MILLIS=30000  # per-request HTTP timeout (ms)

# ── LangSmith ─────────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=          # LangSmith API key (also accepted as LANGSMITH_API_KEY)
LANGCHAIN_PROJECT=

# ── Phoenix ───────────────────────────────────────────────────────────────────
# Set false to exclude Phoenix from the collector pipeline (default: true).
# After changing, rebuild: docker compose build otel-collector
PHOENIX_TRACING_ENABLED=true
# Full OTLP/HTTP endpoint the collector uses to reach Phoenix.
# e.g. http://host:6006/v1/traces
PHOENIX_ENDPOINT=
PHOENIX_PROJECT_NAME=prisma-langgraphed
PHOENIX_CAPTURE_PAYLOADS=true

# ── Langfuse ──────────────────────────────────────────────────────────────────
# Set false to exclude Langfuse from the collector pipeline (default: true).
# After changing, rebuild: docker compose build otel-collector
LANGFUSE_TRACING_ENABLED=true
# Full OTLP/HTTP endpoint the collector uses to reach Langfuse.
# e.g. http://localhost:3000/api/public/otel/v1/traces
LANGFUSE_ENDPOINT=
# Base64 of "pk-lf-...:sk-lf-..." — generate with:
#   python3 -c "import base64; print(base64.b64encode(b'PK:SK').decode())"
LANGFUSE_OTEL_BASIC_AUTH=
# Generate the secrets below with:  openssl rand -base64 32
LANGFUSE_NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
LANGFUSE_SALT=generate_with_openssl_rand_base64_32
